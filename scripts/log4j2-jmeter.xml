<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
  <Appenders>
    <Console name="Console" target="SYSTEM_OUT">
      <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5p %c{1.} - %m%n"/>
    </Console>
  </Appenders>

  <Loggers>
    <!-- Keep summariser output (the summary lines) visible -->
    <Logger name="org.apache.jmeter.reporters.Summariser" level="INFO" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <!-- Suppress all other JMeter INFO noise (thread start/stop, config, parsers, etc.) -->
    <Root level="ERROR">
      <AppenderRef ref="Console"/>
    </Root>
  </Loggers>
</Configuration>
